</main>
<script>
(function () {
  const searchInput = document.getElementById('portal-search-input');
  const items = Array.from(document.querySelectorAll('.feature-card, .tool-nav-item, .app-card'));
  const noResults = document.getElementById('portal-no-results');

  function normalize(text) {
    return String(text || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  function filterItems() {
    const query = normalize(searchInput.value.trim());
    let visible = 0;
    items.forEach((item) => {
      const title = normalize(item.dataset.title || item.querySelector('h1, .app-card-title, .tool-nav-label')?.textContent || '');
      const desc = normalize(item.dataset.description || item.querySelector('p, .app-card-description')?.textContent || '');
      const match = !query || title.includes(query) || desc.includes(query);
      item.style.display = match ? '' : 'none';
      if (match) visible += 1;
    });
    if (noResults) noResults.style.display = visible ? 'none' : 'block';
  }

  if (searchInput) searchInput.addEventListener('input', filterItems);

  const mapModal = document.getElementById('home-map-modal');
  const openMapButton = document.getElementById('open-map-modal');
  const closeMapButtons = document.querySelectorAll('[data-close-map]');
  const mapSearch = document.getElementById('home-map-search');
  const municipalitySelect = document.getElementById('home-map-municipality');
  const mapList = document.getElementById('home-map-list');
  const mapFrame = document.getElementById('home-map-frame');
  const mapLoading = document.getElementById('home-map-loading');
  const branchName = document.getElementById('home-map-branch-name');
  const branchLocation = document.getElementById('home-map-branch-location');
  const branchBadge = document.getElementById('home-map-badge');
  const routeButton = document.getElementById('home-map-route');
  let mapLocations = [];
  let activeMapLocationId = null;

  function buildMapEmbedUrl(location) {
    const searchText = [location.name, location.municipality, 'Cremería Hermanos Coronel'].filter(Boolean).join(', ');
    return `https://www.google.com/maps?q=${encodeURIComponent(searchText)}&output=embed`;
  }

  function setActiveLocation(location) {
    if (!location) return;
    activeMapLocationId = location.id;
    if (mapLoading) mapLoading.classList.add('visible');
    if (mapFrame) mapFrame.src = buildMapEmbedUrl(location);
    if (branchName) branchName.textContent = location.name || 'Sucursal';
    if (branchLocation) branchLocation.textContent = `${location.municipality || 'Municipio no asignado'}${location.status ? ' · ' + location.status : ''}`;
    if (branchBadge) branchBadge.textContent = location.store_type || 'Sucursal';
    if (routeButton) {
      routeButton.href = location.maps_url || '/ubicaciones';
      routeButton.target = location.maps_url ? '_blank' : '_self';
      routeButton.innerHTML = location.maps_url
        ? '<i class="fa-solid fa-diamond-turn-right"></i> Cómo llegar'
        : '<i class="fa-solid fa-list"></i> Ver ubicaciones';
    }
    renderMapList();
  }

  function getFilteredMapLocations() {
    const query = normalize(mapSearch?.value || '');
    const municipality = municipalitySelect?.value || '';
    return mapLocations.filter((location) => {
      const text = normalize(`${location.name || ''} ${location.municipality || ''} ${location.store_type || ''}`);
      const matchesQuery = !query || text.includes(query);
      const matchesMunicipality = !municipality || location.municipality === municipality;
      return matchesQuery && matchesMunicipality;
    });
  }

  function renderMapList() {
    if (!mapList) return;
    const filtered = getFilteredMapLocations();
    mapList.innerHTML = '';
    if (!filtered.length) {
      mapList.innerHTML = '<div class="home-map-empty">No encontré sucursales con ese filtro.</div>';
      return;
    }
    filtered.slice(0, 80).forEach((location) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = `home-map-location-card${location.id === activeMapLocationId ? ' active' : ''}`;
      button.innerHTML = `
        <span class="home-map-location-icon"><i class="fa-solid fa-store"></i></span>
        <span class="home-map-location-text">
          <strong>${location.name || 'Sucursal'}</strong>
          <small>${location.municipality || 'Sin municipio'}${location.branch_number ? ' · #' + location.branch_number : ''}</small>
        </span>
        <i class="fa-solid fa-chevron-right"></i>
      `;
      button.addEventListener('click', () => setActiveLocation(location));
      mapList.appendChild(button);
    });
  }

  function fillMunicipalities() {
    if (!municipalitySelect) return;
    const municipalities = Array.from(new Set(mapLocations.map((location) => location.municipality).filter(Boolean))).sort((a, b) => a.localeCompare(b, 'es'));
    municipalities.forEach((municipality) => {
      const option = document.createElement('option');
      option.value = municipality;
      option.textContent = municipality;
      municipalitySelect.appendChild(option);
    });
  }

  async function loadMapLocations() {
    if (mapLocations.length) return;
    if (mapList) mapList.innerHTML = '<div class="home-map-empty">Cargando sucursales...</div>';
    try {
      const response = await fetch('/api/locations');
      const payload = await response.json();
      mapLocations = (payload.data || []).filter((location) => !location.is_pending);
      fillMunicipalities();
      const firstWithMap = mapLocations.find((location) => location.maps_url) || mapLocations[0];
      renderMapList();
      if (firstWithMap) setActiveLocation(firstWithMap);
    } catch (error) {
      if (mapList) mapList.innerHTML = '<div class="home-map-empty">No se pudieron cargar las ubicaciones.</div>';
    }
  }

  function openMapModal() {
    if (!mapModal) return;
    mapModal.classList.add('open');
    mapModal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('modal-open');
    loadMapLocations();
    setTimeout(() => mapSearch?.focus(), 80);
  }

  function closeMapModal() {
    if (!mapModal) return;
    mapModal.classList.remove('open');
    mapModal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('modal-open');
  }

  if (openMapButton) openMapButton.addEventListener('click', openMapModal);
  closeMapButtons.forEach((button) => button.addEventListener('click', closeMapModal));
  if (mapSearch) mapSearch.addEventListener('input', renderMapList);
  if (municipalitySelect) municipalitySelect.addEventListener('change', renderMapList);
  if (mapFrame) mapFrame.addEventListener('load', () => mapLoading?.classList.remove('visible'));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMapModal();
  });

  document.querySelectorAll('.app-card').forEach((card) => {
    const isSoon = card.dataset.soon === 'true';
    const url = card.dataset.url;
    function openTarget(targetUrl) {
      if (isSoon) {
        alert('Esta aplicación estará disponible próximamente.');
        return;
      }
      if (targetUrl) window.open(targetUrl, '_blank', 'noopener,noreferrer');
    }
    card.addEventListener('click', () => openTarget(url));
    card.querySelectorAll('.app-card-button').forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        openTarget(button.dataset.url || url);
      });
    });
  });
})();
</script>
