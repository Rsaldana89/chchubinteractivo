<%- include('../partials/head', { title }) %>
<main class="portal-home">
  <div class="portal-wrapper">
    <header class="portal-header">
      <div class="brand-logo-wrapper">
        <img src="/assets/img/logo-coronel.png" alt="Cremería Hermanos Coronel" class="brand-logo">
      </div>
      <div class="brand-title">Cremería Hermanos Coronel</div>
      <div class="brand-subtitle">Portal de Aplicaciones CHC</div>
      <p class="welcome-text">Bienvenido al Hub de Páginas y Aplicaciones Coronel.</p>
      <p class="subwelcome-text">Selecciona la herramienta que deseas utilizar.</p>
    </header>

    <section class="portal-feature-strip" aria-label="Accesos principales">
      <a class="feature-card feature-directory" href="/directorio" data-title="Directorio de extensiones" data-description="Extensiones, oficinas, sucursales, teléfonos internos">
        <div class="feature-icon"><i class="fa-solid fa-phone-volume"></i></div>
        <div class="feature-content">
          <span class="feature-kicker">Acceso principal</span>
          <h1>Directorio de extensiones</h1>
          <p>Busca rápido extensiones de sucursales, oficinas, panadería y vigilancia.</p>
          <div class="feature-meta">
            <span><strong><%= counts.extensions %></strong> extensiones</span>
            <span><strong><%= counts.branches %></strong> sucursales</span>
          </div>
        </div>
        <span class="feature-action">Abrir <i class="fa-solid fa-arrow-right"></i></span>
      </a>

      <article class="feature-card feature-locations" data-title="Ubicaciones sucursales como llegar mapas" data-description="Google Maps, rutas, direcciones, municipios">
        <div class="feature-icon"><i class="fa-solid fa-map-location-dot"></i></div>
        <div class="feature-content">
          <span class="feature-kicker">Sucursales</span>
          <h1>Ubicaciones</h1>
          <p>Encuentra sucursales por municipio y abre la ruta en Google Maps.</p>
          <div class="feature-meta">
            <span><strong><%= counts.locations %></strong> ubicaciones</span>
            <span><strong><%= counts.offices %></strong> oficina</span>
          </div>
        </div>
        <div class="feature-action-row">
          <button type="button" id="open-map-modal" class="feature-action feature-action-button">Ver mapa <i class="fa-solid fa-map-location-dot"></i></button>
          <a class="feature-action feature-action-link" href="/ubicaciones">Abrir página <i class="fa-solid fa-arrow-right"></i></a>
        </div>
      </article>
    </section>


    <div id="home-map-modal" class="home-map-modal" aria-hidden="true">
      <div class="home-map-backdrop" data-close-map></div>
      <section class="home-map-dialog" role="dialog" aria-modal="true" aria-labelledby="home-map-title">
        <header class="home-map-header">
          <div>
            <span class="home-map-kicker"><i class="fa-solid fa-map-location-dot"></i> Mapa interactivo</span>
            <h2 id="home-map-title">Ubicaciones de sucursales</h2>
            <p>Busca una sucursal, visualiza el mapa y abre la ruta exacta con el enlace guardado.</p>
          </div>
          <button type="button" class="home-map-close" data-close-map aria-label="Cerrar mapa"><i class="fa-solid fa-xmark"></i></button>
        </header>

        <div class="home-map-body">
          <aside class="home-map-side">
            <div class="home-map-search">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input id="home-map-search" type="text" placeholder="Buscar sucursal o municipio..." autocomplete="off">
            </div>
            <select id="home-map-municipality" class="home-map-select" aria-label="Filtrar municipio">
              <option value="">Todos los municipios</option>
            </select>
            <div id="home-map-list" class="home-map-list"></div>
          </aside>

          <div class="home-map-preview">
            <div class="home-map-frame-wrap">
              <iframe id="home-map-frame" title="Mapa de sucursal" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
              <div id="home-map-loading" class="home-map-loading"><i class="fa-solid fa-location-dot"></i><span>Cargando mapa...</span></div>
            </div>
            <div class="home-map-info-card">
              <div>
                <span id="home-map-badge" class="home-map-badge">Sucursal</span>
                <h3 id="home-map-branch-name">Selecciona una sucursal</h3>
                <p id="home-map-branch-location">El mapa se mostrará aquí.</p>
              </div>
              <div class="home-map-actions">
                <a id="home-map-route" href="/ubicaciones" target="_blank" rel="noopener noreferrer" class="home-map-route-button"><i class="fa-solid fa-diamond-turn-right"></i> Cómo llegar</a>
                <a href="/ubicaciones" class="home-map-page-button"><i class="fa-solid fa-list"></i> Ver página completa</a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <section class="search-section portal-search-section">
      <form class="search-bar-wrapper search-web-form" action="https://www.google.com/search" method="get" target="_blank" rel="noopener noreferrer">
        <label class="search-label" for="web-search-input">Buscar en Google</label>
        <div class="search-row">
          <input id="web-search-input" class="search-input" type="text" name="q" placeholder="Buscar en la web..." autocomplete="off">
          <button type="submit" class="search-submit-button">Buscar</button>
        </div>
      </form>

      <div class="search-bar-wrapper">
        <label class="search-label" for="portal-search-input">Buscar apps y herramientas del hub</label>
        <input id="portal-search-input" class="search-input" type="text" placeholder="Buscar aplicaciones o herramientas..." autocomplete="off">
      </div>
    </section>

    <section class="updates-board" aria-label="Cambios recientes en la plataforma">
      <div class="updates-board-label"><i class="fa-solid fa-bullhorn"></i><span>Cambios recientes</span></div>
      <div class="updates-board-track">
        <div class="updates-board-content">
          <span>Se agregó el nuevo directorio autoadministrable con ubicaciones.</span>
          <span class="updates-divider">•</span>
          <span>Directorio y Ubicaciones quedan como accesos principales.</span>
          <span class="updates-divider">•</span>
          <span>El panel admin permite actualizar extensiones y enlaces de Google Maps.</span>
          <span class="updates-divider">•</span>
          <span>Se conserva el hub de aplicaciones y enlaces de trabajo.</span>
        </div>
      </div>
    </section>

