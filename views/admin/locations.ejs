<%- include('../partials/head', { title }) %>
<div class="admin-layout">
  <%- include('../partials/admin-nav') %>
  <main class="admin-main">
    <div class="admin-header">
      <div>
        <p class="admin-kicker">Administración</p>
        <h1>Ubicaciones</h1>
      </div>
      <a class="admin-button primary" href="/admin/locations/new"><i class="fa-solid fa-plus"></i> Nueva ubicación</a>
    </div>
    <%- include('../partials/flash') %>

    <section class="admin-card">
      <form method="get" class="admin-search">
        <input name="q" value="<%= search %>" placeholder="Buscar por sucursal, municipio, estatus...">
        <button class="admin-button" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Buscar</button>
        <% if (search) { %><a class="admin-button ghost" href="/admin/locations">Limpiar</a><% } %>
      </form>
      <div class="responsive-table">
        <table>
          <thead><tr><th>#</th><th>Sucursal</th><th>Municipio</th><th>Tipo</th><th>Estatus</th><th>Maps</th><th>Ext.</th><th></th></tr></thead>
          <tbody>
            <% rows.forEach((item) => { %>
              <tr>
                <td><%= item.branch_number || '-' %></td>
                <td><strong><%= item.name %></strong></td>
                <td><%= item.municipality %></td>
                <td><span class="table-badge"><%= item.store_type %></span></td>
                <td><%= item.status %><%= item.is_pending ? ' · pendiente' : '' %></td>
                <td><%= item.maps_url ? 'Sí' : 'No' %></td>
                <td><%= item.linked_extensions %></td>
                <td class="table-actions">
                  <a class="table-action" href="/admin/locations/<%= item.id %>/edit">Editar</a>
                  <form method="post" action="/admin/locations/<%= item.id %>/delete" onsubmit="return confirm('¿Eliminar ubicación? Las extensiones vinculadas quedarán sin ubicación.');">
                    <button type="submit" class="danger-link">Eliminar</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
