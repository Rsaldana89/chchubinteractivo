<%- include('../partials/head', { title }) %>
<main class="login-shell">
  <section class="login-card">
    <img src="/assets/img/logo-coronel.png" alt="CHC" class="login-logo">
    <h1>Panel de administración</h1>
    <p>Actualiza extensiones, sucursales y enlaces de ubicación.</p>
    <%- include('../partials/flash') %>
    <form method="post" action="/admin/login" class="form-grid single">
      <label>Usuario
        <input name="username" type="text" autocomplete="username" required autofocus>
      </label>
      <label>Contraseña
        <input name="password" type="password" autocomplete="current-password" required>
      </label>
      <button class="admin-button primary" type="submit"><i class="fa-solid fa-right-to-bracket"></i> Entrar</button>
    </form>
    <a href="/directorio" class="login-back">Volver al directorio</a>
  </section>
</main>
<%- include('../partials/footer') %>
